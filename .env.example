# PaintLead Pro v2 Environment Variables Configuration

# 1. Google Gemini API (For AI Paint Visualizer Siding Analysis)
GEMINI_API_KEY=your_gemini_api_key_here

# 2. Vapi Outbound voice dial triggers
VAPI_API_KEY=your_vapi_api_key_here
VAPI_ASSISTANT_ID=your_chloe_voice_assistant_id_here
VAPI_PHONE_NUMBER_ID=your_vapi_phone_number_identifier_here

# 3. Twilio SMS Dispatch Gateway
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE_NUMBER=your_twilio_outbound_phone_number_here

# 4. Partner Notification Configuration
PARTNER_NOTIFY_PHONE=+18645550100

# 5. Supabase Database Backend (If migrating from LocalStorage client-side)
SUPABASE_URL=your_supabase_project_url_here
SUPABASE_ANON_KEY=your_supabase_anon_key_here
